# =============================================================================
# Phase-0 environment. Copy to .env and fill in. NEVER commit .env — .gitignore
# already covers .env*. All secrets stay here; none belong in git.
# =============================================================================

# --- LiteLLM gateway -------------------------------------------------------
# Master key: mints per-user virtual keys. Generate a strong random value.
# e.g. `python -c "import secrets;print('sk-'+secrets.token_urlsafe(32))"`
LITELLM_MASTER_KEY=sk-CHANGE-ME

# --- Spark A (qwen3-coder via vLLM, OpenAI-compatible) ---------------------
SPARK_A_API_BASE=http://spark-a.internal:8000/v1
SPARK_A_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
SPARK_A_API_KEY=dummy          # vLLM usually ignores auth; set if you enabled it

# --- Azure AI Foundry: Anthropic / Claude (azure_ai provider) --------------
# Native Anthropic Messages API surface. Base URL MUST end in /anthropic.
FOUNDRY_ANTHROPIC_API_BASE=https://<your-resource>.services.ai.azure.com/anthropic
AZURE_API_KEY=CHANGE-ME
# These are your Foundry DEPLOYMENT names (not catalog IDs):
FOUNDRY_CLAUDE_SONNET_DEPLOYMENT=claude-sonnet-4-5
FOUNDRY_CLAUDE_OPUS_DEPLOYMENT=claude-opus-4-1
# If your Claude deployment is Entra-ID-only, drop AZURE_API_KEY and instead set:
# AZURE_TENANT_ID=...
# AZURE_CLIENT_ID=...
# AZURE_CLIENT_SECRET=...

# --- Azure OpenAI: GPT (azure provider) ------------------------------------
AZURE_API_BASE=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=CHANGE-ME
AZURE_OPENAI_API_VERSION=2024-10-21
FOUNDRY_GPT_DEPLOYMENT=gpt-4o
