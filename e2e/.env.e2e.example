# =============================================================================
# E2E environment. Copy to .env.e2e if you want to override defaults. The
# mock-profile values are TEST-ONLY and safe to commit as examples — the master
# key here mints nothing real and reaches no real backend.
#
# For the CLI-AUTH profile (real hosted models via borrowed CLI creds), see
# README.md > "Profile: cli-auth". Any REAL keys go in a gitignored file, never
# here and never in the mock config.
# =============================================================================

# LiteLLM gateway master key (test-only; overrides the compose default).
LITELLM_MASTER_KEY=sk-e2e-master-test-key

# Where the test suite finds the stack (compose publishes both on localhost).
GATEWAY_URL=http://localhost:4000
MOCKD_URL=http://localhost:9100
