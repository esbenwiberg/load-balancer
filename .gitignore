# Secrets — never commit
.env
.env.*
# but DO commit the templates (no secrets in them):
!.env.example
!.env.e2e.example
*.key
*.pem
secrets/
*credentials*

# LiteLLM / local config that may hold keys
litellm-config.local.yaml

# Bicep — generated ARM JSON (we validate with `bicep build --stdout`; never commit
# the transpiled output). Keep .bicep / .bicepparam source; ignore built artifacts.
deploy/azure/**/*.json

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Python (if we add tooling later)
__pycache__/
*.pyc
.venv/
.venv-e2e/
venv/
.pytest_cache/
